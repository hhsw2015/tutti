    "Pro 已过期，请联网验证或重新激活": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro abgelaufen. Bitte online verifizieren oder neu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro expired. Connect to verify or reactivate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro expirado. Conéctate para verificar o reactivar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro expiré. Connectez-vous pour vérifier ou réactiver."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro scaduto. Connettiti per verificare o riattivare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro が期限切れ。ネットに接続して検証または再認証してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 만료됨. 네트워크에 연결하여 확인하거나 다시 활성화하세요."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 已過期，請連線驗證或重新啟用"
          }
        }
      }
    },
