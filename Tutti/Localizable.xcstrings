    "登录系统时静默打开 Tutti，并以菜单栏图标方式驻留。" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Beim Anmelden öffnet Tutti im Hintergrund und bleibt als Menüleistensymbol aktiv." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Opens silently at login and stays in the menubar." } },
