    "Tutti 接管系统音频图标后，控制中心里的音量入口可以关掉。": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobald Tutti die Audioanzeige übernimmt, kann das Lautstärkesymbol im Kontrollzentrum ausgeblendet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once Tutti takes over, the Control Center sound entry can be turned off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando Tutti se hace cargo, el icono de sonido del Centro de control se puede ocultar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois Tutti aux commandes, l'icône de son du Centre de contrôle peut être masquée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando Tutti subentra, l'icona del suono in Centro di Controllo può essere nascosta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti が引き継いだ後は、コントロールセンターの音量項目を隠せます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti가 음원을 맡으면 제어 센터의 사운드 항목은 숨길 수 있습니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti 接管系統音訊圖示後，控制中心裡的音量入口可以關掉。"
          }
        }
      }
    },
