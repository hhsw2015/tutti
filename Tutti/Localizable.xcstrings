    "切换后需重启 Tutti 才会全部生效。": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert einen Neustart von Tutti, um vollständig zu wirken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restart Tutti for the change to take full effect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinicia Tutti para que el cambio surta efecto completo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Redémarrez Tutti pour que le changement prenne effet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riavvia Tutti perché la modifica abbia pieno effetto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変更を完全に反映するには Tutti の再起動が必要です。"
